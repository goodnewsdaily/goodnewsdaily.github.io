  "about.title": "\u041e GoodNewsDaily",
  "about.text1": "GoodNewsDaily \u2014 \u044d\u0442\u043e \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u0430\u044f \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0430 \u0431\u0435\u0437 \u0440\u0435\u043a\u043b\u0430\u043c\u044b, \u043f\u043e\u0441\u0432\u044f\u0449\u0451\u043d\u043d\u0430\u044f \u043f\u043e\u0437\u0438\u0442\u0438\u0432\u043d\u044b\u043c \u0438\u0441\u0442\u043e\u0440\u0438\u044f\u043c, \u043e\u0442\u043b\u0438\u0447\u043d\u043e\u0439 \u043c\u0443\u0437\u044b\u043a\u0435 \u0438 \u0438\u0441\u043a\u0440\u0435\u043d\u043d\u0435\u043c\u0443 \u044e\u043c\u043e\u0440\u0443 \u0441\u043e \u0432\u0441\u0435\u0433\u043e \u043c\u0438\u0440\u0430.",
  "about.text2": "\u041c\u044b \u0432\u0435\u0440\u0438\u043c, \u0447\u0442\u043e \u0445\u043e\u0440\u043e\u0448\u0438\u0435 \u043d\u043e\u0432\u043e\u0441\u0442\u0438 \u0437\u0430\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u044e\u0442 \u0441\u0442\u043e\u043b\u044c\u043a\u043e \u0436\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u044f, \u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0438 \u043f\u043b\u043e\u0445\u0438\u0435. \u041c\u0438\u0440 \u043f\u043e\u043b\u043e\u043d \u043b\u044e\u0434\u0435\u0439, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0440\u0435\u0448\u0430\u044e\u0442 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b, \u0441\u043e\u0437\u0434\u0430\u044e\u0442 \u043a\u0440\u0430\u0441\u043e\u0442\u0443 \u0438 \u043f\u043e\u043c\u043e\u0433\u0430\u044e\u0442 \u0434\u0440\u0443\u0433 \u0434\u0440\u0443\u0433\u0443 \u2014 \u0438\u0445 \u0438\u0441\u0442\u043e\u0440\u0438\u0438 \u0437\u0430\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u044e\u0442 \u0442\u043e\u0433\u043e, \u0447\u0442\u043e\u0431\u044b \u0431\u044b\u0442\u044c \u0440\u0430\u0441\u0441\u043a\u0430\u0437\u0430\u043d\u043d\u044b\u043c\u0438.",
  "about.text3": "\u041d\u0438\u043a\u0430\u043a\u0438\u0445 \u0430\u043b\u0433\u043e\u0440\u0438\u0442\u043c\u043e\u0432. \u041d\u0438\u043a\u0430\u043a\u043e\u0433\u043e \u043a\u043b\u0438\u043a\u0431\u0435\u0439\u0442\u0430. \u041d\u0438\u043a\u0430\u043a\u043e\u0433\u043e \u043d\u0435\u0433\u0430\u0442\u0438\u0432\u0430. \u0422\u043e\u043b\u044c\u043a\u043e \u0445\u043e\u0440\u043e\u0448\u0435\u0435, \u043e\u0442\u043e\u0431\u0440\u0430\u043d\u043d\u043e\u0435 \u0441 \u0434\u0443\u0448\u043e\u0439.",
  "about.values_title": "\u041d\u0430\u0448\u0438 \u0446\u0435\u043d\u043d\u043e\u0441\u0442\u0438",
  "about.value1": "\u041f\u043e\u0437\u0438\u0442\u0438\u0432 \u043f\u0440\u0435\u0436\u0434\u0435 \u0432\u0441\u0435\u0433\u043e \u2014 \u041c\u044b \u0434\u0435\u043b\u0438\u043c\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u0438\u0441\u0442\u043e\u0440\u0438\u044f\u043c\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u0434\u043e\u0445\u043d\u043e\u0432\u043b\u044f\u044e\u0442, \u0438\u043d\u0444\u043e\u0440\u043c\u0438\u0440\u0443\u044e\u0442 \u0438\u043b\u0438 \u0432\u044b\u0437\u044b\u0432\u0430\u044e\u0442 \u0443\u043b\u044b\u0431\u043a\u0443.",
  "about.value2": "\u0413\u043b\u043e\u0431\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u0437\u0433\u043b\u044f\u0434 \u2014 \u0425\u043e\u0440\u043e\u0448\u0438\u0435 \u043d\u043e\u0432\u043e\u0441\u0442\u0438 \u043f\u0440\u043e\u0438\u0441\u0445\u043e\u0434\u044f\u0442 \u043f\u043e\u0432\u0441\u044e\u0434\u0443, \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0432 \u0430\u043d\u0433\u043b\u043e\u044f\u0437\u044b\u0447\u043d\u044b\u0445 \u0441\u0442\u0440\u0430\u043d\u0430\u0445.",
  "about.value3": "\u0411\u0435\u0437 \u0440\u0435\u043a\u043b\u0430\u043c\u044b, \u0431\u0435\u0437 \u043e\u0442\u0441\u043b\u0435\u0436\u0438\u0432\u0430\u043d\u0438\u044f \u2014 \u0411\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u043e \u043d\u0430\u0432\u0441\u0435\u0433\u0434\u0430, \u0441 \u0443\u0432\u0430\u0436\u0435\u043d\u0438\u0435\u043c \u043a \u043a\u043e\u043d\u0444\u0438\u0434\u0435\u043d\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438, \u043e\u0442\u043a\u0440\u044b\u0442\u043e \u0434\u043b\u044f \u0432\u0441\u0435\u0445.",
  "about.value4": "\u0420\u0435\u0430\u043b\u044c\u043d\u044b\u0435 \u0438\u0441\u0442\u043e\u0440\u0438\u0438 \u2014 \u0412\u0441\u0451, \u0447\u0435\u043c \u043c\u044b \u0434\u0435\u043b\u0438\u043c\u0441\u044f, \u043f\u0440\u043e\u0432\u0435\u0440\u0435\u043d\u043e \u0438 \u043f\u043e\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043d\u043e \u0438\u0441\u0442\u043e\u0447\u043d\u0438\u043a\u0430\u043c\u0438. \u041d\u0438\u043a\u0430\u043a\u043e\u0439 \u043b\u043e\u0436\u043d\u043e\u0439 \u043f\u043e\u0437\u0438\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u0438.",

